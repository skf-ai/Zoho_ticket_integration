# Local development env vars (copy to a shell/session; NEVER commit real values).
# In AWS these come from Secrets Manager instead (see SECRET_NAME).
#
#   source these before running:  python -m src.handler   (or tests)
#
# --- Zoho Desk ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_DEPARTMENT_ID=

# --- Meta WhatsApp Cloud API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- AWS (local) ---
AWS_REGION=ap-south-1
STATE_TABLE=whatsapp_conversation_state
# Leave SECRET_NAME unset locally to use the env vars above.
# SECRET_NAME=siddhanta/whatsapp-zoho
